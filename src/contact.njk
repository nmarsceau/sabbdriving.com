			<h2>Phone</h2>
			<a href="tel:18642920259">864.292.0259</a>
			<h2>Email</h2>
			<form class="validate" name="contact" method="post" action="/success/" netlify>
				<label>
					Name<span class="required">required</span>
					<input type="text" name="name" required maxlength="250">
				</label>
				<label>
					Email Address<span class="required">required</span>
					<input type="email" name="email" required maxlength="320">
				</label>
				<label>
					Phone Number<span class="required">required</span>
					<input type="tel" name="phone" required maxlength="20">
				</label>
				<label>
					Message<span class="required">required</span>
					<textarea name="message" rows="6" class="count" maxlength="2500" required></textarea>
				</label>
				<button type="submit" class="button button-primary">Send</button>
			</form>
